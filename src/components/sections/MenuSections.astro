---
import { t, type Locale } from "../../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t[locale];
const prefix = locale === "vi" ? "" : `/${locale}`;

const coffeeGroups = [
  {
    label: tr.coffees.sectionPhin,
    items: [tr.coffees.items.cauDatHoney, tr.coffees.items.buonMaThuotRobusta, tr.coffees.items.baMien],
  },
  {
    label: tr.coffees.sectionFilter,
    items: [tr.coffees.items.daLatNatural, tr.coffees.items.lamDongAnaerobic, tr.coffees.items.sonLaWashed],
  },
];

const drinkSections = [
  {
    label: tr.menu.sections.traditional,
    items: [tr.menu.items.phinTruyenThong, tr.menu.items.phinSuaDa, tr.menu.items.bacXiu],
  },
  {
    label: tr.menu.sections.modern,
    items: [tr.menu.items.espresso, tr.menu.items.pourOver],
  },
  {
    label: tr.menu.sections.cold,
    items: [tr.menu.items.coldBrew],
  },
  {
    label: tr.menu.sections.signature,
    items: [tr.menu.items.eggCoffee, tr.menu.items.coconutSalted],
  },
];

const workshops = Object.values(tr.workshops.items);
---

<section class="py-20 px-6">
  <div class="max-w-7xl mx-auto text-center mb-20" data-reveal>
    <p class="eyebrow mb-4">{locale === "vi" ? "MENU · CÀ PHÊ & ĐỒ UỐNG" : "MENU · COFFEE & DRINKS"}</p>
    <h1 class="font-serif text-4xl md:text-6xl text-bean font-medium mb-6 leading-tight">{tr.coffees.heading}</h1>
    <p class="text-base text-bean-soft max-w-2xl mx-auto">{tr.coffees.lead}</p>
  </div>

  <div class="max-w-6xl mx-auto space-y-20">
    {coffeeGroups.map((group) => (
      <div data-reveal>
        <div class="flex items-baseline gap-4 mb-10 border-b border-bean/15 pb-3">
          <h2 class="font-serif text-2xl md:text-3xl text-bean">{group.label}</h2>
          <span class="flex-1 border-t border-dotted border-bean/20"></span>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {group.items.map((c) => (
            <article class="bg-paper border border-bean/8 p-6 flex flex-col">
              <h3 class="font-serif text-xl text-bean mb-2">{c.name}</h3>
              <p class="text-xs text-bean-soft mb-4">{c.farm}</p>

              <div class="grid grid-cols-2 gap-x-4 gap-y-3 mb-4 mt-auto">
                <div>
                  <p class="font-mono text-[9px] tracking-[0.2em] text-jade-deep mb-1">{tr.coffees.labels.altitude}</p>
                  <p class="font-mono text-xs tabular tracking-wider text-bean">{c.altitude}</p>
                </div>
                <div>
                  <p class="font-mono text-[9px] tracking-[0.2em] text-jade-deep mb-1">{tr.coffees.labels.process}</p>
                  <p class="text-xs text-bean">{c.process}</p>
                </div>
                <div>
                  <p class="font-mono text-[9px] tracking-[0.2em] text-jade-deep mb-1">{tr.coffees.labels.roast}</p>
                  <p class="text-xs text-bean">{c.roast}</p>
                </div>
                <div>
                  <p class="font-mono text-[9px] tracking-[0.2em] text-jade-deep mb-1">{tr.coffees.labels.notes}</p>
                  <p class="text-xs text-bean">{c.notes}</p>
                </div>
              </div>

              <div class="flex items-baseline justify-between gap-3 pt-4 border-t border-bean/10">
                <div>
                  <p class="price text-base">{c.price200}</p>
                  <p class="font-mono text-[10px] tracking-wider text-bean-soft mt-0.5">200g</p>
                </div>
                <div class="text-right">
                  <p class="price text-sm">{c.price1kg}</p>
                  <p class="font-mono text-[10px] tracking-wider text-bean-soft mt-0.5">1kg</p>
                </div>
              </div>

              <p class="font-mono text-[10px] tracking-[0.18em] text-jade-deep uppercase mt-3">{c.stock}</p>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>

  <p class="max-w-3xl mx-auto mt-16 text-xs text-bean-soft text-center font-mono tracking-wider leading-relaxed">{tr.coffees.footnote}</p>
</section>

<section class="py-24 px-6 bg-bean text-paper">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16" data-reveal>
      <p class="eyebrow eyebrow-on-dark mb-4">{locale === "vi" ? "UỐNG TẠI QUÁN" : "IN THE CAFÉ"}</p>
      <h2 class="font-serif text-3xl md:text-5xl text-paper font-medium mb-4 leading-tight">{tr.menu.heading}</h2>
      <p class="text-base text-paper/70 max-w-xl mx-auto">{tr.menu.lead}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-x-16 gap-y-12">
      {drinkSections.map((section) => (
        <div data-reveal>
          <div class="flex items-baseline gap-4 mb-6 border-b border-paper/15 pb-3">
            <h3 class="font-serif text-xl text-paper">{section.label}</h3>
            <span class="flex-1 border-t border-dotted border-paper/15"></span>
          </div>

          <ul class="space-y-5">
            {section.items.map((d) => (
              <li class="grid grid-cols-[1fr_auto] gap-x-4 gap-y-1 items-baseline">
                <h4 class="text-base text-paper">{d.name}</h4>
                <span class="price price-on-dark text-sm whitespace-nowrap">{d.price}</span>
                <p class="col-span-2 text-xs text-paper/65 leading-relaxed">{d.desc}</p>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="max-w-3xl mx-auto mt-16 text-xs text-paper/55 text-center font-mono tracking-wider">{tr.menu.footnote}</p>
  </div>
</section>

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14" data-reveal>
      <p class="eyebrow mb-4">{locale === "vi" ? "LỚP HỌC" : "WORKSHOPS"}</p>
      <h2 class="font-serif text-3xl md:text-5xl text-bean font-medium mb-4 leading-tight">{tr.workshops.heading}</h2>
      <p class="text-base text-bean-soft max-w-xl mx-auto">{tr.workshops.lead}</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {workshops.map((w, i) => (
        <article class="border border-bean/10 p-7 hover:border-jade transition-colors" data-reveal data-reveal-delay={(i % 4) + 1}>
          <div class="flex items-baseline justify-between gap-3 mb-3">
            <h3 class="font-serif text-xl text-bean">{w.name}</h3>
            <span class="price text-sm whitespace-nowrap">{w.price}</span>
          </div>
          <p class="font-mono text-[10px] tracking-[0.18em] text-jade-deep uppercase mb-4">{w.duration} · {w.maxPeople}</p>
          <p class="text-sm text-bean-soft leading-relaxed">{w.desc}</p>
        </article>
      ))}
    </div>

    <div class="text-center mt-12" data-reveal>
      <a href="https://zalo.me/84908123456" target="_blank" rel="noopener" class="inline-flex items-center gap-3 px-7 py-3.5 bg-[#0068ff] text-white hover:bg-[#0052cc] transition-colors text-sm tracking-wide">
        <span class="font-mono font-bold text-xs">Zalo</span>
        {locale === "vi" ? "Đăng ký lớp học" : "Book a workshop"}
      </a>
    </div>
  </div>
</section>
