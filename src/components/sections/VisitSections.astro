---
import { t, type Locale } from "../../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t[locale];

const interiorImage = "/images/visit-interior.png";

const mapEmbedSrc =
  "https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d3919.5!2d106.6794!3d10.7686!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNzMgTmd1eeG7hW4gVGhp4buHbiBUaHXhuq10LCBQaMaw4budbmcgNywgUXXhuq1uIDM!5e0!3m2!1sen!2s!4v1700000000000";
---

<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto text-center mb-16" data-reveal>
    <p class="eyebrow mb-4">{locale === "vi" ? "GHÉ THĂM" : "VISIT"}</p>
    <h1 class="font-serif text-4xl md:text-6xl text-bean font-medium mb-6 leading-tight">{tr.visit.heading}</h1>
    <p class="text-base text-bean-soft max-w-2xl mx-auto">{tr.visit.directions}</p>
  </div>

  <div class="max-w-6xl mx-auto aspect-[16/9] overflow-hidden bg-paper-soft mb-20" data-reveal>
    <img
      src={interiorImage}
      alt=""
      loading="eager"
      width="1400"
      height="787"
      class="w-full h-full object-cover"
    />
  </div>

  <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-12 mb-20">
    <div data-reveal>
      <p class="eyebrow mb-4">{locale === "vi" ? "ĐỊA CHỈ" : "ADDRESS"}</p>
      <p class="font-serif text-2xl text-bean leading-snug mb-3">73 Nguyễn Thiện Thuật</p>
      <p class="text-sm text-bean-soft leading-relaxed">{tr.visit.address}</p>
      <p class="text-sm text-bean-soft leading-relaxed mt-3">{tr.visit.directions}</p>
    </div>

    <div data-reveal data-reveal-delay="1">
      <p class="eyebrow mb-4">{locale === "vi" ? "GIỜ MỞ CỬA" : "HOURS"}</p>
      <p class="font-mono text-xl tabular tracking-wider text-bean mb-3">{tr.visit.hours}</p>
      <p class="text-sm text-bean-soft leading-relaxed">{tr.visit.hoursClosed}</p>
      <div class="mt-6 pt-6 border-t border-bean/10">
        <p class="eyebrow mb-2">{locale === "vi" ? "CHỖ NGỒI" : "SEATING"}</p>
        <p class="text-sm text-bean">{tr.visit.seats}</p>
        <p class="text-xs text-bean-soft mt-1">{tr.visit.parking}</p>
      </div>
    </div>

    <div data-reveal data-reveal-delay="2">
      <p class="eyebrow mb-4">{locale === "vi" ? "LIÊN HỆ" : "CONTACT"}</p>
      <a href={`tel:${tr.visit.phone.replace(/\s/g, "")}`} class="font-mono text-xl tabular tracking-wider text-bean hover:text-jade-deep transition-colors block mb-2">
        {tr.visit.phone}
      </a>
      <a href={`mailto:${tr.visit.email}`} class="font-mono text-sm tabular tracking-wider text-bean-soft hover:text-jade-deep transition-colors block">
        {tr.visit.email}
      </a>
      <a href="https://instagram.com/tramphin.saigon" target="_blank" rel="noopener" class="font-mono text-sm tabular tracking-wider text-bean-soft hover:text-jade-deep transition-colors block mt-1">
        {tr.visit.ig}
      </a>

      <div class="mt-6 flex flex-col gap-3">
        <a href="https://zalo.me/84908123456" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#0068ff] text-white hover:bg-[#0052cc] transition-colors text-sm tracking-wide">
          <span class="font-mono font-bold text-xs">Zalo</span>
          {tr.visit.zalo}
        </a>
        <a href={`tel:${tr.visit.phone.replace(/\s/g, "")}`} class="inline-flex items-center gap-2 px-5 py-2.5 border border-bean text-bean hover:bg-bean hover:text-paper transition-colors text-sm tracking-wide">
          {locale === "vi" ? tr.callNow : tr.callNow}
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto" data-reveal>
    <p class="eyebrow mb-4 text-center">{locale === "vi" ? "BẢN ĐỒ" : "MAP"}</p>
    <div class="aspect-[16/9] bg-paper-soft border border-bean/10">
      <iframe
        title="Map of Trạm Phin"
        src={mapEmbedSrc}
        class="w-full h-full"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
