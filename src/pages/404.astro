---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout locale="vi" page="home" description="Page not found">
  <section class="min-h-[70vh] flex items-center justify-center px-6 py-24">
    <div class="text-center max-w-lg" data-reveal>
      <p class="font-mono text-xs tracking-[0.3em] text-jade-deep mb-6">404 · KHÔNG TÌM THẤY</p>
      <h1 class="font-serif text-4xl md:text-5xl text-bean mb-6 leading-tight">Hẻm này hơi sâu.</h1>
      <p class="text-base text-bean-soft mb-2">
        Trang bạn tìm không có ở đây — nhưng cà phê thì có.
      </p>
      <p class="text-sm text-bean-soft mb-10">
        The page you were looking for is down a different alley — but the coffee is here.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-7 py-3 bg-jade text-paper hover:bg-jade-deep transition-colors text-sm tracking-wide"
      >
        Về trang chủ / Return Home <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
